{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "//#build:bevy-demo", "//#build:book", "//#build:llms-txt"],
      "outputs": ["dist/**"]
    },
    "//#build:bevy-demo": {
      "cache": true,
      "inputs": [
        "Cargo.toml",
        "Cargo.lock",
        "xtask/**",
        "crates/**",
        "examples/bevy-example/**",
        "examples/assets/**"
      ],
      "outputs": ["web/public/bevy-demo/**"]
    },
    "//#build:book": {
      "cache": true,
      "inputs": ["book/**"],
      "outputs": ["web/public/book/**"]
    },
    "//#build:llms-txt": {
      "cache": true,
      "inputs": ["book/src/**", "xtask/templates/llms-header.md"],
      "outputs": ["web/public/llms.txt", "web/public/llms-full.txt"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
