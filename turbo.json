{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "//#build:wasm", "//#build:book", "//#build:llms-txt"],
      "outputs": ["dist/**", ".astro/**"]
    },
    "//#build:wasm": {
      "cache": true,
      "inputs": [
        "Cargo.toml",
        "Cargo.lock",
        "crates/**",
        "examples/bevy-example/**",
        "examples/assets/fonts/**",
        "examples/assets/i18n/**/bevy-example/**",
        "examples/assets/i18n/**/bevy-example.ftl"
      ],
      "outputs": ["web/public/bevy-example/**"]
    },
    "//#build:book": {
      "cache": true,
      "inputs": ["book/**"],
      "outputs": ["web/public/book/**"]
    },
    "//#build:llms-txt": {
      "cache": true,
      "inputs": ["book/**"],
      "outputs": ["web/public/llms.txt"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
