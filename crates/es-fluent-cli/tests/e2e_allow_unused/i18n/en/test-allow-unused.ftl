# Greeting: $name used, $debug_id is allow_unused (passed but optional)
greeting = Hello, { $name }!

# Notification::Alert: $message used, internal_debug is skip (not passed)
notification-Alert = Alert: { $message }

# Notification::Info: $f0 used, $f1 is allow_unused (passed but optional)
notification-Info = Info: { $f0 }
