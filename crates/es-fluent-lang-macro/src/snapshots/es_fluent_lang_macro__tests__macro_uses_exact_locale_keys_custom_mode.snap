impl From<CustomLanguages> for es_fluent::unic_langid::LanguageIdentifier {
    fn from(val: CustomLanguages) -> Self {
        match val {
            CustomLanguages::En => es_fluent::unic_langid::langid!("en"),
            CustomLanguages::FrFr => es_fluent::unic_langid::langid!("fr-FR"),
            CustomLanguages::ZhCn => es_fluent::unic_langid::langid!("zh-CN"),
        }
    }
}
impl From<&CustomLanguages> for es_fluent::unic_langid::LanguageIdentifier {
    fn from(val: &CustomLanguages) -> Self {
        match val {
            CustomLanguages::En => es_fluent::unic_langid::langid!("en"),
            CustomLanguages::FrFr => es_fluent::unic_langid::langid!("fr-FR"),
            CustomLanguages::ZhCn => es_fluent::unic_langid::langid!("zh-CN"),
