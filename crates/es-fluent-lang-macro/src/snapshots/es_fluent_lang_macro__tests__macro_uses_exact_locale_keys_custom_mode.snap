enum CustomLanguages {
    En,
    FrFr,
    ZhCn,
}
impl ::es_fluent::FluentMessage for CustomLanguages {
    fn to_fluent_string_with(
        &self,
        localize: &mut dyn for<'__es_fluent_message> FnMut(
            &str,
            &str,
            Option<
                &::std::collections::HashMap<
                    &str,
                    ::es_fluent::FluentValue<'__es_fluent_message>,
                >,
            >,
        ) -> String,
    ) -> String {
        match self {
            Self::En => localize(env!("CARGO_PKG_NAME"), "en", None),
            Self::FrFr => localize(env!("CARGO_PKG_NAME"), "fr-FR", None),
            Self::ZhCn => localize(env!("CARGO_PKG_NAME"), "zh-CN", None),
        }
    }
}
