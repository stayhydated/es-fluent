impl ::es_fluent::FluentDisplay for Languages {
    fn fluent_fmt(&self, f: &mut ::std::fmt::Formatter<'_>) -> ::std::fmt::Result {
        match self {
            Self::En => {
                write!(
                    f, "{}", ::es_fluent::localize_in_domain("es-fluent-lang",
                    "es-fluent-lang-en", None)
                )
            }
        }
    }
}
