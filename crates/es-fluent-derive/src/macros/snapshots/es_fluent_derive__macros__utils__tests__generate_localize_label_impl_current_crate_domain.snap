impl ::es_fluent::FluentLabel for Greeting {
    fn localize_label<__EsFluentLocalizer: ::es_fluent::FluentLocalizer + ?Sized>(
        localizer: &__EsFluentLocalizer,
    ) -> String {
        ::es_fluent::__private::localize_label(
            localizer,
            (::es_fluent::registry::StaticFluentDomain::from_package_name(
                env!("CARGO_PKG_NAME"),
            ))
                .as_str(),
            "hello",
        )
    }
}
