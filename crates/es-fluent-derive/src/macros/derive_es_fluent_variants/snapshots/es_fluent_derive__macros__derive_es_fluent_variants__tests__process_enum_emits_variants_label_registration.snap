///Variants of [`Status`].
pub enum StatusVariants {
    ///The `Ready` variant of [`Status`].
    Ready,
    ///The `Failed` variant of [`Status`].
    Failed,
}
impl ::es_fluent::FluentMessage for StatusVariants {
    fn to_fluent_string_with(
        &self,
        localize: &mut dyn for<'__es_fluent_message> FnMut(
            &str,
            &str,
            Option<
                &::std::collections::HashMap<
                    &str,
                    ::es_fluent::FluentValue<'__es_fluent_message>,
                >,
            >,
        ) -> String,
    ) -> String {
        match self {
            Self::Ready => {
                localize(env!("CARGO_PKG_NAME"), "status_variants-Ready", None)
            }
            Self::Failed => {
                localize(env!("CARGO_PKG_NAME"), "status_variants-Failed", None)
            }
        }
    }
}
