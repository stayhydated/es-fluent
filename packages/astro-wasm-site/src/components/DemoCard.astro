---
import { withBaseUrl } from "../site";

interface Props {
  href: string;
  title: string;
}

const { href, title } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<div class="demo-card">
  <a href={withBaseUrl(baseUrl, href)} class="overlay" aria-label={title}></a>
  <div class="title">{title}</div>
  <slot />
</div>

<style>
  .demo-card {
    position: relative;
    padding: 1.5rem;
    background: var(--color-bg-card);
    border: 1px solid rgba(160, 255, 0, 0.3);
    border-radius: 0.5rem;
    color: var(--color-text);
    transition: all 0.3s ease;
    margin-bottom: 1rem;
  }

  .demo-card:hover {
    border-color: var(--color-accent);
    transform: translateX(4px);
    box-shadow: 0 0 5px var(--color-accent-glow), inset 0 0 5px var(--color-accent-glow);
  }

  .demo-card .overlay {
    position: absolute;
    inset: 0;
    pointer-events: auto;
    z-index: 0;
  }

  .demo-card :global(p) {
    position: relative;
    pointer-events: none;
    z-index: 1;
  }

  .demo-card :global(p a) {
    pointer-events: auto;
  }

  .demo-card .title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
    text-shadow: 0 0 10px var(--color-accent-glow);
  }
</style>
