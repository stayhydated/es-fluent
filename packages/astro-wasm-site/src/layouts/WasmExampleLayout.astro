---
import { withBaseUrl } from "../site";
import Layout from "./Layout.astro";

interface Props {
  title: string;
  backHref?: string;
  backLabel?: string;
}

const {
  title,
  backHref = withBaseUrl(import.meta.env.BASE_URL, "/demos"),
  backLabel = "Back to Demos",
} = Astro.props;
---

<Layout title={title} fullscreen>
  <a
    href={backHref}
    class="fixed top-4 left-4 px-4 py-2 bg-bg-card/90 text-primary no-underline rounded font-sans text-sm z-1000 border border-primary/30 hover:border-primary btn-primary"
  >
    &larr; {backLabel}
  </a>

  <slot />
</Layout>

<style>
  :global(body) {
    position: relative;
    display: block;
    min-height: 100vh;
    min-height: 100dvh;
  }

  :global(body > canvas) {
    position: fixed;
    inset: 0;
    display: block;
    width: 100vw !important;
    height: 100vh !important;
    height: 100dvh !important;
    margin: 0;
  }

  :global(canvas) {
    display: block;
  }
</style>
