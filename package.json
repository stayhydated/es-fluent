{
  "name": "es-fluent",
  "private": true,
  "workspaces": [
    "web"
  ],
  "scripts": {
    "build": "turbo build",
    "build:bevy-demo": "env -u RUSTC_WRAPPER cargo xtask build-bevy-demo",
    "build:book": "cargo run -p xtask -- build-book",
    "build:llms-txt": "cargo run -p xtask -- build-llms-txt",
    "build:web": "turbo run build --filter=web",
    "fmt": "oxfmt",
    "lint": "oxlint"
  },
  "devDependencies": {
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "turbo": "^2.8.20"
  },
  "packageManager": "bun@1.3.10"
}
