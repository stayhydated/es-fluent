{
  "name": "es-fluent",
  "private": true,
  "workspaces": [
    "web",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "build:book": "cargo run -p xtask -- build-book",
    "build:llms-txt": "cargo run -p xtask -- build-llms-txt",
    "build:wasm": "env -u RUSTC_WRAPPER cargo xtask build-wasm-examples",
    "build:web": "turbo run build --filter=web",
    "dev": "turbo dev",
    "fmt": "oxfmt",
    "generate:wasm-examples-schema": "cargo xtask generate-wasm-examples-schema",
    "lint": "oxlint",
    "verify:wasm": "cargo xtask verify-wasm-examples",
    "verify:wasm-markers": "cargo xtask verify-wasm-markers"
  },
  "devDependencies": {
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "turbo": "^2.8.20"
  },
  "packageManager": "bun@1.3.10"
}
