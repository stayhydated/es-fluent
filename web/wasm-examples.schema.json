{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WasmExamplesManifest",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "examples": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/WasmExample"
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "$schema",
    "examples"
  ],
  "$defs": {
    "CopyPath": {
      "type": "object",
      "properties": {
        "destination": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "source",
        "destination"
      ]
    },
    "WasmExample": {
      "type": "object",
      "properties": {
        "copy": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/CopyPath"
          }
        },
        "crate_dir": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "out_dir": {
          "type": "string"
        },
        "out_name": {
          "type": "string"
        },
        "wasm_pack_args": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "id",
        "crate_dir",
        "out_dir",
        "out_name"
      ]
    }
  }
}
