---
import Layout from "@/layouts/Layout.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<Layout title={title} fullscreen>
  <a
    href={`${baseUrl}/`}
    class="fixed top-4 left-4 px-4 py-2 bg-bg-card/90 text-primary no-underline rounded font-sans text-sm z-1000 border border-primary/30 hover:border-primary btn-primary"
  >
    &larr; Back to Examples
  </a>

  <slot />
</Layout>

<style>
  :global(body) {
    position: relative;
    display: block;
    min-height: 100vh;
  }

  :global(body > canvas) {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: block;
  }

  :global(canvas) {
    display: block;
  }
</style>
