---
import Layout from "@/layouts/Layout.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<Layout title={title} fullscreen>
  <a
    href={`${baseUrl}/`}
    class="fixed top-4 left-4 px-4 py-2 bg-bg-card/90 text-primary no-underline rounded font-sans text-sm z-1000 border border-primary/30 hover:border-primary btn-primary"
  >
    &larr; Back to Demos
  </a>

  <slot />
</Layout>

<style>
  :global(body) {
    position: relative;
    display: block;
    min-height: 100vh;
    min-height: 100dvh;
  }

  :global(body > canvas) {
    position: fixed;
    inset: 0;
    display: block;
    width: 100vw !important;
    height: 100vh !important;
    height: 100dvh !important;
    margin: 0;
  }

  :global(canvas) {
    display: block;
  }
</style>
