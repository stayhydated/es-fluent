---
const baseUrl = import.meta.env.BASE_URL;

const links = [
  { href: baseUrl, label: "Home" },
  { href: `${baseUrl}/demos`, label: "Demos" },
];
---

<nav class="flex w-full justify-center px-8 py-4">
  <ul class="bg-bg-card border-accent/30 flex list-none gap-1 rounded-lg border p-1">
    {links.map(({ href, label }) => (
      <li>
        <a
          href={href}
          class="text-text hover:text-primary hover:bg-bg-hover block rounded-md px-4 py-2 no-underline transition-colors"
        >
          {label}
        </a>
      </li>
    ))}
  </ul>
</nav>
