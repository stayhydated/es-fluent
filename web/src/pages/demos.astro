---
import Layout from "@/layouts/Layout.astro";
import DemoCard from "@/components/DemoCard.astro";
---

<Layout title="es-fluent - Demos">
  <div class="max-w-3xl mx-auto px-8 py-12">
    <h1 class="text-4xl font-bold text-primary mb-8 glow-primary">Demos</h1>

    <DemoCard href="/bevy-example/" title="Bevy Example">
      <p class="description">
        Interactive UI demo showcasing es-fluent i18n integration with with <a href="https://bevy.org/">Bevy</a>
      </p>
    </DemoCard>

  </div>
</Layout>

<style>
  .description {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .description a {
    color: var(--color-secondary);
    font-weight: 600;
    text-decoration: none;
  }

  .description a:hover {
    text-decoration: underline;
  }
</style>
