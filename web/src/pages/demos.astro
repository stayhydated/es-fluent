---
import Layout from "@stayhydated/astro-wasm-site/layouts/Layout.astro";
import DemoCard from "@stayhydated/astro-wasm-site/components/DemoCard.astro";
import {
  getWasmExamples,
  wasmExampleHref,
  wasmExampleTitle,
} from "@stayhydated/astro-wasm-site/wasm-examples";
import Navigation from "../components/Navigation.astro";
const examples = await getWasmExamples();
---

<Layout title="es-fluent - Demos">
  <Navigation slot="navigation" />
  <div class="max-w-3xl mx-auto px-8 py-12">
    <h1 class="text-4xl font-bold text-primary mb-8 glow-primary">Demos</h1>

    {
      examples.map((example) => (
        <DemoCard href={wasmExampleHref(example)} title={wasmExampleTitle(example)}>
          <p class="description">
            Interactive wasm demo built from <code>{example.crate_dir}</code>.
          </p>
        </DemoCard>
      ))
    }
  </div>
</Layout>

<style>
  .description {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .description code {
    font-family: monospace;
  }
</style>
