---
import WasmExampleLayout from "@stayhydated/astro-wasm-site/layouts/WasmExampleLayout.astro";
import WasmLoader from "@stayhydated/astro-wasm-site/components/WasmLoader.astro";
import {
  getWasmExamples,
  wasmExampleModuleUrl,
  wasmExampleTitle,
  type WasmExample,
} from "@stayhydated/astro-wasm-site/wasm-examples";
import { displayNameFromBaseUrl } from "@stayhydated/astro-wasm-site/site";

interface Props {
  example: WasmExample;
}

export async function getStaticPaths() {
  const examples = await getWasmExamples();

  return examples.map((example) => ({
    params: { exampleId: example.id },
    props: { example },
  }));
}

const baseUrl = import.meta.env.BASE_URL;
const displayName = displayNameFromBaseUrl(baseUrl);
const { example } = Astro.props;
const title = wasmExampleTitle(example);
---

<WasmExampleLayout title={`${title} - ${displayName}`}>
  <WasmLoader moduleUrl={wasmExampleModuleUrl(baseUrl, example)} />
</WasmExampleLayout>
