---
import Layout from "@/layouts/Layout.astro";
import { displayNameFromBaseUrl } from "@/util";
import { Content as Readme } from "../../../README.md";

const displayName = displayNameFromBaseUrl();
---

<Layout title={displayName}>
  <div class="mx-auto px-8 py-12 prose prose-invert prose-cyan max-w-none">
    <Readme />
  </div>
</Layout>

<style is:global>
  .prose {
    color: #e0e0e0;
  }
  .prose h1 {
    color: #00f0ff;
    text-shadow: 0 0 10px rgba(0, 240, 255, 0.5);
  }
  .prose h2 {
    color: #a0ff00;
    text-shadow: 0 0 10px rgba(160, 255, 0, 0.5);
  }
  .prose h3 {
    color: #ff00a0;
    text-shadow: 0 0 10px rgba(255, 0, 160, 0.5);
  }
  .prose code {
    background: #0a0a0a;
    border: 1px solid rgba(160, 255, 0, 0.3);
    padding: 0.2em 0.4em;
    border-radius: 4px;
    color: #00f0ff;
  }
  .prose pre {
    background: #000000;
    border: 1px solid rgba(160, 255, 0, 0.3);
    border-radius: 8px;
    padding: 1rem;
    overflow-x: auto;
  }
  .prose pre code {
    background: transparent;
    border: none;
    padding: 0;
    color: #e0e0e0;
  }
  .prose a {
    color: #00f0ff;
  }
  .prose strong {
    color: #ffffff;
  }
  .prose ul {
    list-style-type: disc;
    padding-left: 1.5em;
  }
  .prose li {
    margin-bottom: 0.5em;
  }
  .prose img {
    border-radius: 8px;
  }
</style>
